---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import TrustRibbon from "../../components/TrustRibbon.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppCTA from "../../components/WhatsAppCTA.astro";

import { site } from "../../data/site";
import { blogs, getBlog } from "../../data/blogs";

export async function getStaticPaths() {
  return blogs.map((b) => ({ params: { post: b.slug }, props: { slug: b.slug } }));
}

const { slug } = Astro.props;
const blog = getBlog(slug)!;
const url = `${site.url}/blog/${blog.slug}`;

const titleParts = blog.emTitle ? blog.title.split(blog.emTitle) : [blog.title];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${url}#article`,
      headline: blog.title,
      description: blog.description,
      image: site.url + blog.heroImage,
      datePublished: blog.publishedDate,
      dateModified: blog.modifiedDate,
      author: { "@type": "Organization", name: site.name, url: site.url },
      publisher: { "@type": "Organization", name: site.name, url: site.url },
      mainEntityOfPage: url,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: site.url },
        { "@type": "ListItem", position: 2, name: "Blog", item: `${site.url}/blog` },
        { "@type": "ListItem", position: 3, name: blog.title, item: url },
      ],
    },
  ],
};
---

<BaseLayout title={`${blog.title} | ${site.name}`} description={blog.description} canonical={url} schemaJson={schema}>
  <Header />
  <TrustRibbon />

  <div class="container container-narrow">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/blog">Blog</a>
      <span class="sep">/</span>
      <span class="current">{blog.title}</span>
    </nav>
  </div>

  <header class="container container-tight" style="padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 4vw, 3rem) clamp(2rem, 5vw, 4rem);">
    <div style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: 2rem; display: flex; gap: 1.25rem; flex-wrap: wrap; align-items: center;">
      <span>Coatings · {blog.readingTime} read</span>
      <span style="display:inline-flex; align-items:center; gap:0.4rem;"><span style="width:4px; height:4px; background:var(--fg-cream-faint); border-radius:50%;"></span>Updated Apr 2026</span>
    </div>
    <h1 style="font-family: var(--font-editorial); font-weight: 500; font-size: clamp(2.25rem, 5.5vw, 4.25rem); letter-spacing: -0.015em; line-height: 1.08; margin-bottom: 1.75rem;">
      {blog.emTitle ? (
        <>{titleParts[0]}<em style="font-style: italic; color: var(--accent);">{blog.emTitle}</em>{titleParts[1]}</>
      ) : blog.title}
    </h1>
    <p class="lead" style="font-size: clamp(1.125rem, 1.6vw, 1.375rem); line-height: 1.5; color: var(--fg-cream-dim); margin-bottom: 2.25rem; max-width: 60ch;">{blog.description}</p>
    <div style="display:flex; align-items:center; gap:1rem; padding-top:2rem; border-top:1px solid var(--border-subtle); font-size:0.875rem;">
      <div style="width:44px; height:44px; border-radius:50%; background:var(--accent); color:var(--bg-deep); display:grid; place-items:center; font-family:var(--font-display); font-weight:800; font-size:1.25rem; transform:skewX(-9deg);"><span style="transform:skewX(9deg); display:block;">J</span></div>
      <div>
        <div style="color:var(--fg-cream); font-weight:600; font-size:0.9375rem;">{site.name}</div>
        <div style="color:var(--fg-cream-faint); font-size:0.8125rem; margin-top:1px;">Udayamperoor workshop · Since {site.founded}</div>
      </div>
    </div>
  </header>

  <div style="aspect-ratio: 16 / 9; max-width: 1180px; margin: 0 auto 4rem; padding: 0 clamp(1.25rem, 4vw, 3rem);" class="reveal">
    <div style="width: 100%; height: 100%; border-radius: var(--r-lg); overflow: hidden; position: relative;">
      <img src={blog.heroImage} alt={blog.heroImageAlt} style="width: 100%; height: 100%; object-fit: cover;" />
    </div>
  </div>

  <article class="container container-tight reveal" style="padding: 0 clamp(1.25rem, 4vw, 3rem) 4rem;">
    <div class="article-body" set:html={blog.body}></div>
  </article>

  <section style="background: linear-gradient(180deg, rgba(15, 26, 43, 0.6), transparent); padding: 4rem 0;">
    <div class="container container-narrow">
      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;" class="reveal">
        <a href="/ceramic-coating-udayamperoor" style="padding:1.75rem; border-radius:var(--r-md); background:rgba(20,32,50,0.55); border:1px solid var(--border-subtle); transition:all var(--t-std);">
          <div style="font-size:0.7rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--accent); margin-bottom:0.75rem;">Service · Udayamperoor</div>
          <h3 style="font-size:1.25rem; margin-bottom:0.625rem;">Ceramic Coating in Udayamperoor</h3>
          <p style="color:var(--fg-cream-dim); font-size:0.9375rem; line-height:1.55;">Multi-year hydrophobic protection. Drop your car at our workshop — same-day quote.</p>
        </a>
        <a href="/ceramic-coating-kochi" style="padding:1.75rem; border-radius:var(--r-md); background:rgba(20,32,50,0.55); border:1px solid var(--border-subtle);">
          <div style="font-size:0.7rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--accent); margin-bottom:0.75rem;">Service Hub · Kochi</div>
          <h3 style="font-size:1.25rem; margin-bottom:0.625rem;">Ceramic Coating across Kochi</h3>
          <p style="color:var(--fg-cream-dim); font-size:0.9375rem; line-height:1.55;">Tier breakdown, pricing, area coverage. The full guide before you book.</p>
        </a>
        <a href="/coating-comparison" style="padding:1.75rem; border-radius:var(--r-md); background:rgba(20,32,50,0.55); border:1px solid var(--border-subtle);">
          <div style="font-size:0.7rem; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; color:var(--accent); margin-bottom:0.75rem;">Compare</div>
          <h3 style="font-size:1.25rem; margin-bottom:0.625rem;">Ceramic vs Graphene vs Borophine</h3>
          <p style="color:var(--fg-cream-dim); font-size:0.9375rem; line-height:1.55;">Side-by-side breakdown. Which coating is right for your driving?</p>
        </a>
      </div>
    </div>
  </section>

  <section style="background: linear-gradient(135deg, rgba(15, 26, 43, 0.85), rgba(74, 95, 193, 0.12)); border-top:1px solid var(--border-subtle); border-bottom:1px solid var(--border-subtle); padding: 4rem 0;">
    <div class="container container-tight" style="text-align:center;">
      <div class="eyebrow" style="margin-bottom: 1.25rem; justify-content:center;">Talk to us</div>
      <h2 class="h2" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin-bottom: 1.25rem;">Bring the car. Or just WhatsApp the photos.</h2>
      <p style="color: var(--fg-cream-dim); font-size: 1.125rem; max-width: 50ch; margin: 0 auto 2rem;">Free vehicle inspection. Same-day quote. No commitment until you decide.</p>
      <div style="display:inline-flex; gap:1.25rem; flex-wrap:wrap; justify-content:center;">
        <WhatsAppCTA />
        <a href={`tel:${site.phone}`} class="cta-secondary">Or call {site.phoneDisplay}</a>
      </div>
    </div>
  </section>

  <Footer />

  <style>
    .article-body p, .article-body ul, .article-body ol { font-family: var(--font-editorial); font-size: 1.1875rem; line-height: 1.7; color: var(--fg-cream-dim); margin-bottom: 1.5rem; max-width: 68ch; }
    .article-body strong { color: var(--fg-cream); font-weight: 600; }
    .article-body em { font-style: italic; color: var(--fg-cream); }
    .article-body h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); margin: 3.5rem 0 1.5rem; max-width: 28ch; }
    .article-body h3 { font-size: clamp(1.25rem, 2vw, 1.5rem); margin: 2.5rem 0 1rem; max-width: 32ch; }
    .article-body a { color: var(--accent); border-bottom: 1px solid currentColor; padding-bottom: 1px; transition: color var(--t-quick); }
    .article-body a:hover { color: var(--fg-cream); }
    .article-body ul, .article-body ol { padding-left: 1.5rem; }
    .article-body li { margin-bottom: 0.75rem; padding-left: 0.5rem; }
    .article-body li::marker { color: var(--accent); }
    .article-body .callout { padding: 2rem 2.25rem; background: rgba(15, 26, 43, 0.65); border-left: 3px solid var(--accent); border-radius: 0 var(--r-md) var(--r-md) 0; margin: 2.5rem 0; }
    .article-body .callout .label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.875rem; }
    .article-body .callout p { font-family: var(--font-body); font-size: 1rem; line-height: 1.6; color: var(--fg-cream); margin-bottom: 0; }
    .article-body .pull-quote { font-family: var(--font-editorial); font-style: italic; font-size: clamp(1.5rem, 2.8vw, 2rem); line-height: 1.35; color: var(--fg-cream); margin: 3rem 0; padding: 2rem 0 2rem 2rem; border-left: 3px solid var(--accent); max-width: 62ch; }
    .article-body .inline-tier-table { width: 100%; max-width: 68ch; margin: 2rem 0; border: 1px solid var(--border-subtle); border-radius: var(--r-md); overflow: hidden; font-family: var(--font-body); }
    .article-body .inline-tier-table table { width: 100%; border-collapse: collapse; }
    .article-body .inline-tier-table th, .article-body .inline-tier-table td { padding: 1rem 1.25rem; text-align: left; font-size: 0.9375rem; border-bottom: 1px solid var(--border-subtle); }
    .article-body .inline-tier-table th { background: rgba(15, 26, 43, 0.6); font-weight: 600; font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--fg-cream-faint); }
    .article-body .inline-tier-table td { color: var(--fg-cream); }
    .article-body .inline-tier-table tbody tr:last-child td { border-bottom: none; }
  </style>
</BaseLayout>
